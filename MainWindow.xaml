<Window x:Class="MrMergePdfStamper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PDF Imposition Stamper" Height="620" Width="900" MinHeight="520" MinWidth="760">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="Исходный PDF:"/>
            <TextBox x:Name="InputFileTextBox" Grid.Column="2" MinWidth="420" Margin="0,0,0,0"/>
            <Button Grid.Column="4" Padding="18,6" Content="Обзор..." Click="BrowseInput_Click"/>
        </Grid>

        <GroupBox Grid.Row="2" Header="Таблица тиража" Padding="8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button Content="Добавить строку" Padding="14,5" Margin="0,0,8,0" Click="AddRow_Click"/>
                    <Button Content="Удалить строку" Padding="14,5" Margin="0,0,8,0" Click="RemoveRow_Click"/>
                    <TextBlock VerticalAlignment="Center" Foreground="DimGray" Text="Ctrl+V: вставка из Excel (Страница\tКопии)"/>
                </StackPanel>

                <DataGrid x:Name="JobsDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          PreviewKeyDown="JobsDataGrid_PreviewKeyDown">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ спуска" IsReadOnly="True" Binding="{Binding SpreadNumber}" Width="120"/>
                        <DataGridTextColumn Header="Номер страницы" Binding="{Binding SourcePage, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Количество копий" Binding="{Binding Copies, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <Expander Grid.Row="3" Header="Настройки штампа" Margin="0,12,0,0" IsExpanded="False">
            <Grid Margin="10,6,10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Отступ справа (мм)"/>
                    <TextBox x:Name="RightOffsetTextBox" Text="10"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Отступ сверху (мм)"/>
                    <TextBox x:Name="TopOffsetTextBox" Text="5"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Шрифт"/>
                    <TextBox x:Name="FontNameTextBox" Text="Helvetica-Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Размер"/>
                    <TextBox x:Name="FontSizeTextBox" Text="16"/>
                </StackPanel>
            </Grid>
        </Expander>

        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <ProgressBar x:Name="MainProgressBar" Height="18" Minimum="0" Maximum="100"/>
                <TextBlock x:Name="StatusTextBlock" Margin="0,6,0,0" Foreground="DimGray" TextWrapping="Wrap"/>
            </StackPanel>
            <Button Grid.Column="1" Height="42" Content="СТАРТ" FontSize="16" FontWeight="Bold" Margin="12,0,0,0" Click="Start_Click"/>
        </Grid>
    </Grid>
</Window>
